{
	"$schema": "../gen/schemas/desktop-schema.json",
	"identifier": "default",
	"description": "Capability for the main window",
	"windows": ["main"],
	"permissions": [
		"core:default",
		"core:app:allow-set-app-theme",
		"autostart:default",
		"dialog:allow-open",
		"dialog:allow-save",
		"notification:default",
		"opener:default",
		"process:default",
		"updater:default"
	]
}
